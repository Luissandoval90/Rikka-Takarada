// Supongamos que tu evento recibe 'sock' (el bot) y 'update' (la actualización del grupo)
module.exports = async (sock, update) => {
    // 1. Extraemos los datos del evento
    const { id, participants, action, author } = update;
    
    // Aquí tienes tu JSON (si lo importas desde otro archivo, ignora esta variable)
    const idiomas = {
        "promote": {
            "header": "*Recientemente se ha promovido un miembro a administrador*",
            "group": "*◦ Grupo:* @group",
            "new_admin": "*◦ Nuevo admin:* @user",
            "executed_by": "*◦ Ejecutado por:* @user"
        },
        "demote": {
            "header": "*Recientemente se ha degradado un administrador a miembro*",
            "group": "*◦ Grupo:* @group",
            "removed_admin": "*◦ Se quitó a:* @user",
            "executed_by": "*◦ Ejecutado por:* @user"
        },
        // ... (aquí van el resto de tus eventos: add, remove, etc.)
    };

    // Si la acción no está en nuestro JSON, no hacemos nada
    if (!idiomas[action]) return;

    try {
        // 2. Obtenemos el nombre del grupo
        const groupMetadata = await sock.groupMetadata(id);
        const groupName = groupMetadata.subject;

        // 3. Identificamos quién ejecutó la acción (author)
        // Si no hay author, asumimos que fue el mismo usuario
        const autorJid = author || participants[0]; 
        const autorNumero = autorJid.split('@')[0]; // <-- Extrae SOLO el número, evita [object Object]

        // 4. Procesamos a cada participante afectado
        for (let participanteJid of participants) {
            const participanteNumero = participanteJid.split('@')[0]; // <-- Extrae SOLO el número
            const evento = idiomas[action];
            let mensaje = "";

            // Armamos el texto base dependiendo de la acción
            if (action === 'promote') {
                mensaje = `${evento.header}\n${evento.group}\n${evento.new_admin}\n${evento.executed_by}`;
            } else if (action === 'demote') {
                mensaje = `${evento.header}\n${evento.group}\n${evento.removed_admin}\n${evento.executed_by}`;
            } else if (action === 'add') {
                mensaje = `${evento.header}\n${evento.group}\n${evento.added_user}\n${evento.added_by}`;
            } else if (action === 'remove') {
                mensaje = `${evento.header}\n${evento.group}\n${evento.removed_user}\n${evento.removed_by}`;
            }

            // ⚠️ LA SOLUCIÓN AL PROBLEMA ⚠️
            // Reemplazamos los datos uno por uno. 
            // JavaScript reemplaza la PRIMERA coincidencia que encuentre de arriba hacia abajo.

            // a. Reemplazamos el grupo
            mensaje = mensaje.replace('@group', groupName);
            
            // b. Reemplazamos el PRIMER '@user' (el miembro afectado) por su número real
            mensaje = mensaje.replace('@user', `@${participanteNumero}`);
            
            // c. Reemplazamos el SEGUNDO '@user' (el administrador que ejecutó la acción)
            mensaje = mensaje.replace('@user', `@${autorNumero}`);

            // 5. Enviamos el mensaje al grupo mencionando a los usuarios para que se pinten de azul
            await sock.sendMessage(id, {
                text: mensaje,
                mentions: [participanteJid, autorJid] // Arreglo (Array) necesario para etiquetar
            });
        }
    } catch (error) {
        console.error("Error al enviar evento de grupo:", error);
    }
};
